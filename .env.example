# Postgres connection string (Neon). Use the POOLED connection string for the app.
# Example: postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# A non-pooled / direct connection is recommended for migrations (optional).
# DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"
