# Postgres connection string (Neon). Use the POOLED connection string for the app.
# Example: postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# A non-pooled / direct connection is recommended for migrations (optional).
# DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Authentication -------------------------------------------------------
# REQUIRED in production. A random secret used to sign login sessions.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Optional overrides for the shared office login. Defaults match what the
# office was given: usernames hodges1/hodges2/hodges3, password "appliance1".
# APP_USERNAMES="hodges1,hodges2,hodges3"
# APP_PASSWORD="appliance1"
